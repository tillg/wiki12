# wiki12 stack configuration. Copy to .env and adjust as needed.
# (.env is gitignored; docker-compose and `just` load it automatically.)

# --- PostgreSQL ---
POSTGRES_USER=wiki12
POSTGRES_PASSWORD=wiki12
POSTGRES_DB=wiki12
POSTGRES_PORT=8083

# --- Keycloak (sole user store; seeds admin/admin) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8089

# --- A12 Data Service ---
DATA_SERVICE_PORT=8082

# --- Node model-lifecycle service ---
MODEL_LIFECYCLE_PORT=8090

# --- Web client ---
CLIENT_PORT=8081

# --- CLI (when run on the host against the running stack) ---
WIKI12_DATA_SERVICE_URL=http://localhost:8082
WIKI12_MODEL_LIFECYCLE_URL=http://localhost:8090
